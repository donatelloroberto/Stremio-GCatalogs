{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vercel:build": "node ./build-vercel.mjs && pnpm -w --filter @workspace/stremio-piratebay-ui run vercel:build"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "base-64": "^1.0.0",
    "bottleneck": "^2.19.5",
    "byte-size": "^7.0.1",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "delay": "5.0.0",
    "drizzle-orm": "catalog:",
    "episode-parser": "^2.0.2",
    "express": "^5",
    "got": "^11.8.6",
    "is-video": "^1.0.1",
    "lodash": "^4.18.1",
    "magnet-uri": "^6.2.0",
    "magnet2torrent-js": "^1.4.0",
    "p-map": "^4.0.0",
    "p-pipe": "^3.1.0",
    "parse-torrent-title": "^2.1.0",
    "pino": "^9",
    "pino-http": "^10",
    "ramda": "^0.29.1",
    "stremio-addon-sdk": "^1.6.10",
    "video-name-parser": "^1.4.7"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
